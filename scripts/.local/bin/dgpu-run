#!/usr/bin/env bash
# Run a command on the NVIDIA dGPU via PRIME render offload, leaving the
# AMD iGPU (which drives the internal panel and the GNOME compositor)
# untouched. Usage: dgpu-run minecraft-launcher
exec env \
  __NV_PRIME_RENDER_OFFLOAD=1 \
  __NV_PRIME_RENDER_OFFLOAD_PROVIDER=NVIDIA-G0 \
  __GLX_VENDOR_LIBRARY_NAME=nvidia \
  __VK_LAYER_NV_optimus=NVIDIA_only \
  "$@"
