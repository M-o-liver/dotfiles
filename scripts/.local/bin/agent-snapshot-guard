#!/usr/bin/env python3
import json
import os
import re
import sys
import time

STAMP_PATH = os.path.expanduser("~/.cache/agent-snapshot-stamp")
STAMP_MAX_AGE_SECONDS = 30 * 60

SYSTEM_CHANGE_PATTERNS = [
    r"\bdnf\b.*\b(install|remove|erase|upgrade|update|swap|reinstall|distro-sync|autoremove)\b",
    r"\bdnf\b.*\bcopr\b.*\b(enable|disable|remove)\b",
    r"\brpm\b\s+.*-[a-zA-Z]*[iUe]",
    r"\bgrubby\b",
    r"\bgrub2-mkconfig\b",
    r"\bgrub2-install\b",
    r"\bdracut\b",
    r"\bsystemctl\b.*\b(enable|disable|mask|unmask)\b",
    r"\bakmods\b",
    r"(\btee\b|\bcp\b|\bmv\b|\bln\b|\bsed\b\s+-i).*\s/etc/",
    r">\s*/etc/",
]

COMPILED_PATTERNS = [re.compile(p) for p in SYSTEM_CHANGE_PATTERNS]


def main():
    try:
        payload = json.load(sys.stdin)
    except Exception:
        sys.exit(0)

    if payload.get("tool_name") != "Bash":
        sys.exit(0)

    command = payload.get("tool_input", {}).get("command", "")
    if not command:
        sys.exit(0)

    if not any(p.search(command) for p in COMPILED_PATTERNS):
        sys.exit(0)

    try:
        stamp_age = time.time() - os.path.getmtime(STAMP_PATH)
    except OSError:
        stamp_age = None

    if stamp_age is None or stamp_age > STAMP_MAX_AGE_SECONDS:
        sys.stderr.write(
            'BLOCKED by snapshot guard: run `snap-now "<description>"` then retry.\n'
        )
        sys.exit(2)

    sys.exit(0)


if __name__ == "__main__":
    main()
