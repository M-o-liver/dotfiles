#!/usr/bin/env bash
# Riced temp summary for CPU/GPU/NVMe/RAM/WiFi, styled to match the
# starship prompt palette (~/.config/starship.toml): purple label pills,
# green/amber/red status pills, powerline arrows.
set -euo pipefail

j="$(sensors -j)"
get() { jq -r "$1 // \"n/a\"" <<<"$j"; }

tctl=$(get '.["k10temp-pci-00c3"].Tctl.temp1_input')
tccd1=$(get '.["k10temp-pci-00c3"].Tccd1.temp3_input')
tccd2=$(get '.["k10temp-pci-00c3"].Tccd2.temp4_input')
igpu=$(get '.["amdgpu-pci-0700"].edge.temp1_input')
ram1=$(get '.["spd5118-i2c-9-50"].temp1.temp1_input')
ram2=$(get '.["spd5118-i2c-9-51"].temp1.temp1_input')
wifi=$(get '.["mt7921_phy0-pci-0600"].temp1.temp1_input')
nvme1=$(get '.["nvme-pci-0300"].Composite.temp1_input')
nvme2=$(get '.["nvme-pci-0400"].Composite.temp1_input')

dgpu="n/a"
if command -v nvidia-smi >/dev/null 2>&1; then
    dgpu="$(nvidia-smi --query-gpu=temperature.gpu --format=csv,noheader,nounits 2>/dev/null || echo n/a)"
fi

# starship.toml palette
PURPLE="167;139;250"
DARK="26;22;37"
GREEN="74;222;128"
AMBER="249;201;107"
RED="243;139;168"
ARROW=$''
ICON=$'' # fa-microchip

fg() { printf '\033[38;2;%sm' "$1"; }
bg() { printf '\033[48;2;%sm' "$1"; }
reset() { printf '\033[0m'; }

# warn/crit thresholds per component
status_color() {
    local val=$1 warn=$2 crit=$3
    [ "$val" = "n/a" ] && { echo "$AMBER"; return; }
    awk -v v="$val" -v w="$warn" -v c="$crit" \
        'BEGIN{ if (v>=c) print "red"; else if (v>=w) print "amber"; else print "green"; exit }' \
        | { read -r r; case "$r" in
              red) echo "$RED" ;;
              amber) echo "$AMBER" ;;
              *) echo "$GREEN" ;;
          esac; }
}

fmt() { [ "$1" = "n/a" ] && echo " n/a " || printf ' %.1f°C ' "$1"; }

row() {
    local label="$1" val="$2" warn="$3" crit="$4"
    local vcolor
    vcolor=$(status_color "$val" "$warn" "$crit")

    bg "$PURPLE"; fg "$DARK"
    printf ' %s %s ' "$ICON" "$label"
    reset; fg "$PURPLE"; bg "$vcolor"
    printf '%s' "$ARROW"
    reset; fg "$DARK"; bg "$vcolor"
    printf '%s' "$(fmt "$val")"
    reset; fg "$vcolor"
    printf '%s' "$ARROW"
    reset
    printf '\n'
}

echo
row "CPU (Tctl)"    "$tctl"  70 90
row "CPU CCD1"      "$tccd1" 70 90
row "CPU CCD2"      "$tccd2" 70 90
row "iGPU (610M)"   "$igpu"  75 90
row "dGPU (RTX5070)" "$dgpu" 75 85
row "NVMe 1"        "$nvme1" 60 75
row "NVMe 2"        "$nvme2" 60 75
row "RAM stick 1"   "$ram1"  50 55
row "RAM stick 2"   "$ram2"  50 55
row "WiFi"          "$wifi"  70 85
echo
