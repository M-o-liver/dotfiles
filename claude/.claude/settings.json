{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(journalctl *)",
      "Bash(hyprctl *)",
      "Bash(lspci*)",
      "Bash(lsblk*)",
      "Bash(nvidia-smi*)",
      "Bash(free*)",
      "Bash(modinfo*)",
      "Bash(rpm -q*)",
      "Bash(dnf history*)",
      "Bash(dnf list*)",
      "Bash(dnf repolist*)",
      "Bash(dnf repoquery*)",
      "Bash(cat /sys/class/power_supply/*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add *)",
      "Bash(git commit*)",
      "Bash(stow *)",
      "Bash(snap-now*)"
    ],
    "deny": [
      "Read(~/.ssh/**)",
      "Read(~/.gnupg/**)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Bash(dd *)",
      "Bash(mkfs*)",
      "Bash(parted*)",
      "Bash(sfdisk*)",
      "Bash(wipefs*)"
    ],
    "ask": [
      "Bash(sudo *)",
      "Bash(git push*)"
    ]
  },
  "model": "claude-fable-5[1m]",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.local/bin/agent-snapshot-guard"
          }
        ]
      }
    ]
  },
  "effortLevel": "medium",
  "theme": "dark"
}
